generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id               Int       @id @default(autoincrement())
  vessel_owner_id  Int
  vessel_id        Int
  charger_id       Int
  type             String    // "CHARGING", "V2G_DISCHARGE"
  start_time       DateTime
  end_time         DateTime
  status           String    @default("pending") // "pending", "active", "completed", "cancelled"
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  
  // Relations
  transactions     V2gTransaction[]
}

model V2gTransaction {
  id               Int       @id @default(autoincrement())
  booking_id       Int       @unique
  price_per_kwh    Float
  energy_discharged Float    // in kWh
  payment          Float
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  
  // Relations
  booking          Booking   @relation(fields: [booking_id], references: [id])
}